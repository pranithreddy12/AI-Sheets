# ──────────────────────────────────────────────
# AI Sheets — Ollama Configuration
# ──────────────────────────────────────────────
# All AI features run locally via Ollama.
# No data is sent to any external API or cloud service.

# Ollama server URL (default: http://localhost:11434)
VITE_OLLAMA_URL=http://localhost:11434

# Default model to use (e.g., llama3, mistral, codellama)
# Leave empty to auto-detect whatever model is currently loaded
VITE_OLLAMA_MODEL=
